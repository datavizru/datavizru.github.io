{
  "app": "make-your-chart-template",
  "version": 1,
  "size": { "width": 640, "height": 640 },
  "style": {
    "markColor": "#4c6ef5",
    "backgroundColor": "#ffffff",
    "scheme": "tableau10",
    "strokeWidth": 2,
    "showLegend": true,
    "showPoints": false,
    "text": {
      "title":      { "font": "system-ui, sans-serif", "size": 18, "color": "#2b2b29", "bold": true,  "italic": false },
      "subtitle":   { "font": "system-ui, sans-serif", "size": 13, "color": "#8a8a85", "bold": false, "italic": false },
      "axisTitleX": { "font": "system-ui, sans-serif", "size": 12, "color": "#5a5a55", "bold": false, "italic": false },
      "axisTitleY": { "font": "system-ui, sans-serif", "size": 12, "color": "#5a5a55", "bold": false, "italic": false },
      "axisLabelX": { "font": "system-ui, sans-serif", "size": 11, "color": "#6a6a64", "bold": false, "italic": false },
      "axisLabelY": { "font": "system-ui, sans-serif", "size": 11, "color": "#6a6a64", "bold": false, "italic": false },
      "legend":     { "font": "system-ui, sans-serif", "size": 11, "color": "#2b2b29", "bold": false, "italic": false },
      "comment":    { "font": "system-ui, sans-serif", "size": 12, "color": "#8a8a85", "bold": false, "italic": true },
      "footer":     { "font": "system-ui, sans-serif", "size": 11, "color": "#b3b3ae", "bold": false, "italic": false }
    },
    "axes": {
      "x": {
        "line":   { "show": true,  "color": "#d0d7de", "width": 1 },
        "ticks":  { "show": true,  "auto": true, "width": 1, "length": 4, "step": null },
        "labels": { "show": true,  "padding": 4, "step": null, "angle": 0 },
        "grid":   { "show": false, "color": "#ededeb", "width": 1 }
      },
      "y": {
        "line":   { "show": false, "color": "#d0d7de", "width": 1 },
        "ticks":  { "show": false, "auto": true, "width": 1, "length": 4, "step": null },
        "labels": { "show": true,  "padding": 4, "step": null, "angle": 0 },
        "grid":   { "show": true,  "color": "#ededeb", "width": 1 }
      }
    }
  }
}
